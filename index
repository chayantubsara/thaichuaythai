<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <!-- รองรับ Mobile เต็มรูปแบบ -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Thai Plus Calc">
    <meta name="mobile-web-app-capable" content="yes">
    
    <title>Thai Chuay Thai Plus</title>
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="data:application/json,{
        &quot;name&quot;: &quot;Thai Chuay Thai Plus&quot;,
        &quot;short_name&quot;: &quot;ThaiPlus&quot;,
        &quot;start_url&quot;: &quot;.&quot;,
        &quot;display&quot;: &quot;standalone&quot;,
        &quot;background_color&quot;: &quot;#f0f2f5&quot;,
        &quot;theme_color&quot;: &quot;#2563eb&quot;
    }">

    <style>
        :root { --glass: rgba(255, 255, 255, 0.95); --primary: #2563eb; --bg: #f0f2f5; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); margin: 0; padding: 15px; padding-top: 40px; }
        .app-container { max-width: 500px; margin: auto; }
        .card { background: var(--glass); backdrop-filter: blur(10px); padding: 20px; border-radius: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 20px; }
        input { width: 100%; padding: 15px; margin: 8px 0; border: 1px solid #ddd; border-radius: 12px; box-sizing: border-box; font-size: 16px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .result-box { background: #1e293b; color: white; padding: 20px; border-radius: 16px; margin-top: 10px; }
        h1 { text-align: center; color: #1e293b; font-size: 1.5em; margin-bottom: 20px; }
        h3 { margin-top: 0; color: #2563eb; }
        .hint { font-size: 0.85em; color: #666; margin-top: 10px; }
    </style>
</head>
<body>

<div class="app-container">
    <h1>ไทยช่วยไทยพลัส</h1>
    
    <div class="card">
        <div class="grid">
            <input type="number" id="wallet" placeholder="เงิน Wallet" oninput="App.update()">
            <input type="number" id="dailyLimit" placeholder="สิทธิ์รัฐ/วัน" oninput="App.update()">
            <input type="number" id="monthlyLimit" placeholder="สิทธิ์รัฐ/เดือน" oninput="App.update()">
        </div>
        <input type="number" id="price" placeholder="ราคาสินค้า (ปล่อยว่างหาค่าสูงสุด)" oninput="App.update()">
    </div>

    <div class="card" id="results">
        <div id="output">กรอกข้อมูลเพื่อคำนวณ...</div>
    </div>
</div>

<script>
class ThaiChuayPlusEngine {
    constructor() { this.config = { govtRatio: 0.6, userRatio: 0.4, maxDaily: 200 }; }

    calculateMaxPurchase(wallet, dailyRem, monthlyRem) {
        const eff = Math.min(dailyRem, monthlyRem, this.config.maxDaily);
        return Math.min(eff / 0.6, wallet / 0.4);
    }

    calculate(price, wallet, dailyRem, monthlyRem) {
        let govtSupport = Math.min(price * this.config.govtRatio, dailyRem, monthlyRem, this.config.maxDaily);
        return { govtSupport, userPay: price - govtSupport, canBuy: wallet >= (price - govtSupport) };
    }
}

const App = {
    engine: new ThaiChuayPlusEngine(),
    update() {
        const p = parseFloat(document.getElementById('price').value);
        const w = parseFloat(document.getElementById('wallet').value) || 0;
        const dr = parseFloat(document.getElementById('dailyLimit').value) || 200;
        const mr = parseFloat(document.getElementById('monthlyLimit').value) || 1000;

        let html = "";
        if (!p) {
            const max = this.engine.calculateMaxPurchase(w, dr, mr);
            html = `<h3>ซื้อได้สูงสุด: <span style="color:#2563eb">${max.toFixed(2)} บาท</span></h3>
                    <p class="hint">ซื้อได้โดยไม่ต้องเติมเงินเพิ่ม</p>`;
        } else {
            const res = this.engine.calculate(p, w, dr, mr);
            html = `<h3>สรุปยอด</h3>
                    <div class="result-box">
                        <p>รัฐช่วย: ${res.govtSupport.toFixed(2)} บ.</p>
                        <p>เราจ่าย: ${res.userPay.toFixed(2)} บ.</p>
                        <p>${res.canBuy ? "✅ ซื้อได้เลย" : "❌ ขาดเงิน: " + (res.userPay - w).toFixed(2) + " บ."}</p>
                    </div>`;
        }
        document.getElementById('output').innerHTML = html;
    }
};
</script>
</body>
</html>
